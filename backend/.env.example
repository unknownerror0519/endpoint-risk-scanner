# Backend configuration

# Firestore collection containing endpoint docs
FIRESTORE_COLLECTION=endpoint data

# Firestore collection containing scan status/results (must be different)
FIRESTORE_SCAN_COLLECTION=endpoint_scans

# Optional explicit project id (otherwise uses default credentials project)
# FIRESTORE_PROJECT_ID=your-gcp-project-id

# Auth
# Preferred on Cloud Run: use the runtime service account + IAM (ADC)
# Local dev option: point GOOGLE_APPLICATION_CREDENTIALS at a service account key
# GOOGLE_APPLICATION_CREDENTIALS=product/secrets/serviceAccountKey.json

# CORS for local frontend
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


